# ─── AI ENGINE ───────────────────────────────────────────────
# Copy this to ai_engine/.env and fill in your values

GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=fairness-platform-uploads
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ─── BACKEND ─────────────────────────────────────────────────
# Copy this to backend/.env and fill in your values

PORT=3001
FRONTEND_URL=http://localhost:5173
AI_ENGINE_URL=http://localhost:8000

FIREBASE_PROJECT_ID=your-firebase-project-id
GCS_BUCKET_NAME=fairness-platform-uploads
GCS_KEY_FILE=./service-account-key.json

BIGQUERY_DATASET=bias_analytics
BIGQUERY_TABLE=analysis_results
GCP_PROJECT_ID=your-gcp-project-id

# ─── FRONTEND ────────────────────────────────────────────────
# Copy this to frontend/.env.local and fill in your values

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_BACKEND_URL=http://localhost:3001

# ─── NOTES ───────────────────────────────────────────────────
# service-account-key.json — download from Firebase Console
# → Project Settings → Service accounts → Generate new private key
# Place the downloaded file in both:
# → backend/service-account-key.json
# → ai_engine/service-account-key.json
# NEVER commit this file to git