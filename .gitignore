    # Node
    node_modules/
    npm-debug.log*
    .npm
    *.log

    # Python
    __pycache__/
    *.py[cod]
    venv/
    env/
    .venv/
    *.pyc

    # Environment variables — NEVER commit
    .env
    .env.local
    .env.*.local
    *.env

    # Firebase — NEVER commit
    .firebase/
    firebase-debug.log
    .firebaserc

    # Google Cloud — NEVER commit
    service-account-key.json
    *-firebase-adminsdk-*.json
    gcloud-credentials.json

    # Build outputs
    frontend/dist/
    frontend/build/
    *.tsbuildinfo

    # IDE
    .vscode/
    .idea/
    .DS_Store

    # Coverage
    coverage/
    .coverage
    htmlcov/

    # Temp
    *.tmp
    tmp/